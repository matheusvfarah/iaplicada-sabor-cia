# Frontend (Vite) — expostas ao cliente, nunca colocar chaves secretas aqui
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase CLI (link do projeto local ao remoto, push de migrations)
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# Uso server-side apenas (n8n, scripts) — NUNCA expor ao frontend
SUPABASE_SERVICE_ROLE_KEY=

# Segredo do endpoint /api/pedidos/simular (header x-webhook-secret),
# usado pelo workflow n8n WF3 — server-side apenas
ORDER_SIMULATOR_SECRET=

# Segredo dos endpoints /api/alertas/metas-em-risco e /api/alertas/metas
# (header x-webhook-secret), usado pelo workflow n8n WF1 — server-side apenas
METAS_ALERT_SECRET=
